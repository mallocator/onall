{
    "name": "onall",
    "version": "3.0.0",
    "description": "Tiny EventEmitter helper that fires when all (or any) of a set of events have been emitted.",
    "main": "index.js",
    "types": "index.d.ts",
    "type": "module",
    "sideEffects": false,
    "exports": {
        ".": {
            "types": "./index.d.ts",
            "import": "./index.js",
            "default": "./index.js"
        }
    },
    "files": [
        "index.js",
        "index.d.ts",
        "helpers.js",
        "README.md",
        "CHANGELOG.md",
        "LICENSE"
    ],
    "keywords": [
        "onall",
        "onany",
        "eventemitter",
        "events",
        "promise",
        "abortsignal"
    ],
    "license": "Apache-2.0",
    "homepage": "https://github.com/mallocator/onall",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/mallocator/onall.git"
    },
    "author": {
        "name": "Ravi Gairola",
        "email": "mallox@pyxzl.net",
        "url": "https://github.com/mallocator"
    },
    "bugs": {
        "url": "https://github.com/mallocator/onall/issues",
        "email": "mallox@pyxzl.net"
    },
    "engines": {
        "node": ">=16"
    },
    "scripts": {
        "test": "vitest run",
        "test:watch": "vitest",
        "coverage": "vitest run --coverage",
        "prepublishOnly": "vitest run"
    },
    "devDependencies": {
        "@vitest/coverage-v8": "^2.1.5",
        "vitest": "^2.1.5"
    }
}